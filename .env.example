# PostgreSQL settings used for Kubernetes secret rendering and the Django backend.
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=postgres.database.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Django backend settings.
DJANGO_SECRET_KEY=your_django_secret_key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,xmaxx.ai
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://xmaxx.ai
DJANGO_TIME_ZONE=UTC

# GitHub webhook and OAuth settings for home-backend.
# The OAuth client ID comes from the GitHub OAuth App.
# The OAuth secret is provided directly through GITHUB_OAUTH_CLIENT_SECRET.
# Optional token for git/GitHub CLI or automation on this machine.
GIT_ACCESS_TOKEN=your_git_access_token
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_OAUTH_REDIRECT_URI=https://xmaxx.ai/api/auth/github/callback/
GITHUB_OAUTH_SCOPES=read:user,user:email

# Google OAuth settings for home-backend.
# Use this callback URL in Google Cloud:
# https://xmaxx.ai/api/auth/google/callback/
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://xmaxx.ai/api/auth/google/callback/
GOOGLE_OAUTH_SCOPES=openid,email,profile

# Frontend commerce settings for XMAXX Developer Access.
VITE_STRIPE_PRODUCT_ID=prod_UHXHHhIqeNr9YX
VITE_STRIPE_PAYMENT_LINK=your_stripe_payment_link
VITE_XMAXX_DEVELOPER_COMMUNITY_URL=your_private_community_url
